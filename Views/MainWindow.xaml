<Window x:Class="XsltEmployeeWpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:XsltEmployeeWpf.ViewModels"
        Title="Employee Salary Processor"
        Height="500"
        Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
                    Grid.Row="0"
                    Margin="0,0,0,10">
            <Button Content="Обновить расчёты"
                    Command="{Binding RefreshCommand}"
                    Width="140"
                    Margin="0,0,10,0" />
            <Button Content="Добавить запись..."
                    Command="{Binding AddItemCommand}"
                    Width="140" />
        </StackPanel>

        <DataGrid x:Name="EmployeeGrid"
                  Grid.Row="1"
                  ItemsSource="{Binding Employees}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  FrozenColumnCount="2">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Фамилия"
                                    Binding="{Binding Surname}"
                                    Width="120" />
                <DataGridTextColumn Header="Имя"
                                    Binding="{Binding Name}"
                                    Width="120" />
                
                <DataGridTextColumn Header="Итого"
                                    Binding="{Binding TotalAmount, StringFormat={}{0:F2}}"
                                    Width="100" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <TextBlock Text="Общая сумма выплат: "
                       FontWeight="Bold"
                       VerticalAlignment="Center" />
            <TextBlock Text="{Binding GrandTotal, StringFormat={}{0:F2}}"
                       FontWeight="Bold"
                       Margin="5,0,0,0"
                       VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>